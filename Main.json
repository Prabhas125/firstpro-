      "parameters": {
        "jsCode": "// Parse Groq LLM response\nconst raw = $json.choices[0].message.content.trim();\n\nlet data;\ntry {\n  data = JSON.parse(raw);\n} catch(e) {\n  // Strip markdown code fences if present\n  const clean = raw.replace(/```json|```/g, '').trim();\n  data = JSON.parse(clean);\n}\n\n// Get patient details from Code in JavaScript2\nconst patient = $('Code in JavaScript2').first().json;\n\nconst today = new Date().toISOString().slice(0, 10);\n\nfunction makeRow(type, item) {\n  return {\n    json: {\n      patientId:   patient.patientId,\n      patientName: patient.patientName,\n      roomNo:      patient.roomNo,\n      ward:        patient.ward,\n      type,\n      itemName:    item.name  || '',\n      doseTime:    item.time  || '',\n      doseDate:    item.date  || today,\n      status:      'pending',\n      fromId:      patient.fromId\n    }\n  };\n}\n\nconst rows = [];\n\nfor (const m of data.medicines  || []) rows.push(makeRow('Medicine',  m));\nfor (const i of data.injections || []) rows.push(makeRow('Injection', i));\n\nreturn rows;"
      },
