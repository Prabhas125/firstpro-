      "parameters": {
        "jsCode": "const text = $json.text || '';\nconst parts = text.split(/\\s+/);\n\nconst patientId   = parts[0] || '';\nconst patientName = ((parts[1] || '') + ' ' + (parts[2] || '')).trim();\n\nconst roomIndex = parts.findIndex(p => p.toLowerCase() === 'room');\nconst wardIndex = parts.findIndex(p => p.toLowerCase() === 'ward');\n\nconst roomNo = roomIndex !== -1 ? (parts[roomIndex + 1] || '') : '';\nconst ward   = wardIndex !== -1 ? (parts[wardIndex + 1] || '') : '';\n\nreturn [{\n  json: {\n    fromId:      $json.fromId,\n    patientId,\n    patientName,\n    roomNo,\n    ward\n  }\n}];\n"
      },
