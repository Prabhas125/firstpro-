        "jsCode": "const msg = $json.message;\n\nif (!msg) {\n  return [];\n}\n\nconst fromId = msg.chat.id;     // used as key for doctor\nconst type = msg.voice ? 'voice' : 'text';\n\nconst out = {\n  fromId,\n  type\n};\n\nif (type === 'text') {\n  out.text = msg.text || '';\n} else if (type === 'voice') {\n  out.fileId = msg.voice.file_id;\n}\n\nreturn [{ json: out }];\n"
      },
