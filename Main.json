        "jsCode": "const voiceItem = $('Code in JavaScript').first().json;\nconst sheetItems = $input.all();\n\nconst matching = sheetItems.filter(i =>\n  String(i.json.fromId) === String(voiceItem.fromId)\n);\n\nif (!matching.length) {\n  throw new Error('No registered patient found. Please send patient details as text first.');\n}\n\nconst patient = matching[matching.length - 1].json;\n\nreturn [{\n  json: {\n    fromId:      voiceItem.fromId,\n    fileId:      voiceItem.fileId,\n    patientId:   patient.patientId,\n    patientName: patient.patientName,\n    roomNo:      patient.roomNo,\n    ward:        patient.ward\n  }\n}];"
