  "nodes": [
    {
      "parameters": {
        "jsCode": "let data = $json;\n\nif (typeof data.content === 'string') {\n  try {\n    data = JSON.parse(data.content);\n  } catch (e) {\n    throw new Error('AI output is not valid JSON: ' + data.content);\n  }\n}\n\nconst basePatientId   = data.patientId   || '';\nconst basePatientName = data.patientName || '';\nconst today = new Date().toISOString().slice(0, 10);\n\nconst out = [];\n\nfunction addRow(type, entry) {\n  out.push({\n    json: {\n      patientId:   basePatientId,\n      patientName: basePatientName,\n      roomNo:      data.roomNo || '',\n      ward:        data.ward   || '',\n      type,\n      itemName:    entry.name  || '',\n      doseTime:    entry.time  || '',\n      doseDate:    entry.date  || today   // use AI-extracted date or today\n    }\n  });\n}\n\n(data.medicines  || []).forEach(m => addRow('Medicine',  m));\n(data.injections || []).forEach(i => addRow('Injection', i));\n\nreturn out;\n"
      },
